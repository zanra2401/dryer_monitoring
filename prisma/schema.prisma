// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql" // atau "mysql" sesuai database Anda
}

enum BinStatus {
  EMPTY
  UPAIR
  DOWNAIR
}

enum LotStatus {
  UPAIR
  DOWNAIR
 COMPLETED
}

model User {
  userId   Int    @id @default(autoincrement()) @map("user_id")
  username String @unique
  password String 
  fullName String @map("full_name")
  role     String
  lots     Lot[]  @relation("CreatedLots")
  canAccess Daccess[]

  @@map("users")
}


model Daccess {
  userId Int @map("user_id")
  areaId Int @map("area_id")

  user  User  @relation(fields: [userId], references: [userId])
  dryer DryerArea @relation(fields: [areaId], references: [areaId])

  @@id([areaId, userId])
  @@map("dryer_access")
}

model DryerArea {
  areaId   Int       @id @default(autoincrement()) @map("area_id")
  name     String    @unique
  bins     Bin[]
  channels Channel[]

  accessibleFor  Daccess[]

  @@map("dryer_areas")
}

model Channel {
  channelId     String       @id @map("channel_id")
  areaId        Int       @map("area_id")
  apiKey        String    @map("api_key")
  nummberOfBin  Int       @map("number_of_bin")

  dryerArea     DryerArea @relation(fields: [areaId], references: [areaId])
  binsTop       Bin[]     @relation("BinChannelTop")
  binsBottom    Bin[]     @relation("BinChannelBottom")

  @@map("channels")
}

model Bin {
  binNumber       Int       @map("bin_number")
  areaId          Int       @map("area_id")
  channelIdTop    String?   @map("channel_id_top")
  channelIdBottom String?   @map("channel_id_bottom")
  fieldTempTop    String?   @map("field_temp_top")
  fieldRhTop      String?   @map("field_rh_top")
  fieldTempBottom String?   @map("field_temp_bottom")
  fieldRhBottom   String?   @map("field_rh_bottom")
  binStatus       BinStatus @default(EMPTY) @map("bin_status")
  occupiedBy      String?   @map("occupied_by")
  
  dryerArea       DryerArea @relation(fields: [areaId], references: [areaId]) 
  channelTop      Channel?  @relation("BinChannelTop", fields: [channelIdTop], references: [channelId], onDelete: SetNull)
  channelBottom   Channel?  @relation("BinChannelBottom", fields: [channelIdBottom], references: [channelId], onDelete: SetNull)
  binLogs         BinLog[]

  @@id([binNumber, areaId])
  @@map("bins")
}

model Lot {
  lotId        Int       @id @default(autoincrement()) @map("lot_id")
  lotNumber    String    @unique @map("lot_number")
  hybrid       String?
  quality      String?
  netToBin     Float?  @map("net_to_bin")
  initialMc    Float?  @map("initial_mc")
  status       LotStatus @default(UPAIR)
  downAirAt    DateTime?  @map("down_air_at")
  downMC       Float?  @map("down_mc")
  createdBy    Int?      @map("create_by")
  binNumber    Int       @map("bin_number")
  areaId       Int       @map("area_id")
  startTime    DateTime  @default(now()) @map("start_time")
  endTime      DateTime? @map("end_time")
  endMC        Float?    @map("end_mc")
  depth        Float?    @map("depth")

  user         User?     @relation("CreatedLots", fields: [createdBy], references: [userId])
  mcLogs       LotMcLog[]

  @@map("lots")
}

model BinLog {
  binLogId            Int      @id @default(autoincrement()) @map("bin_log_id")
  binNumber           Int      @map("bin_number")
  areaId              Int      @map("area_id")
  timestampThingspeak DateTime @map("timestamp_thingspeak")
  statusBin           String   @map("status_bin")
  tempTop             Float?   @map("temp_top")
  rhTop               Float?   @map("rh_top")
  tempBottom          Float?   @map("temp_bottom")
  rhBottom            Float?   @map("rh_bottom")
  remark              String?  @map("remark")
  isEphemeral         Boolean  @default(false) @map("is_ephemeral")

  bin                 Bin      @relation(fields: [binNumber, areaId], references: [binNumber, areaId], onDelete: Cascade)

  @@map("bin_logs")
}

model LotMcLog {
  lotMcLogId  Int      @id @default(autoincrement()) @map("lot_mc_log_id")
  lotId       Int      @map("lot_id")
  mc          Float    @map("mc")
  checkerName String?  @map("checker_name")
  remark      String?  @map("remark")
  createdAt   DateTime @default(now()) @map("created_at")

  lot         Lot      @relation(fields: [lotId], references: [lotId], onDelete: Cascade)

  @@map("lot_mc_logs")
}