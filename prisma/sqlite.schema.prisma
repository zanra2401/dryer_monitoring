datasource db {
  provider = "sqlite"
}

enum FlagType {
    NUMBER
    STRING
    BOOLEAN
}

enum StatusJob {
    ACTIVE
    INACTIVE
}

generator client {
  provider = "prisma-client"
  output   = "../app/generated/sqlite"
}

// Tabel untuk menyimpan Flag Key-Value (Konfigurasi Global)
model SystemFlag {
  key   String @id
  value String @unique
  type  FlagType
}

// Tabel untuk menyimpan data Job Tracker dengan presisi
model JobTracker {
  JobId           String    @id @map("job_id")
  LotId           Int       @map("lot_id")
  BinId           Int       @map("bin_id")
  ExecuteTime     DateTime  @map("execute_time")
  IntervalMinutes Int       @default(30) @map("interval_minutes")
  status          StatusJob @default(ACTIVE)
  attemptCount    Int       @default(0) @map("attempt_count")
  lastError       String?   @map("last_error")
  lockedAt        DateTime? @map("locked_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
}


model MustExecutedJob {
    JobId         Int       @id @default(autoincrement()) @map("job_id")
    ExecutedTime  DateTime  @default(now()) @map("executed_time")
    LotId         Int       @map("lot_id")
    BinId         Int       @map("bin_id")
    TrackerJobId  String?   @map("tracker_job_id")
    status        StatusJob @default(ACTIVE)
    errorMessage  String?   @map("error_message")
    createdAt     DateTime  @default(now()) @map("created_at")
}